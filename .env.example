DISCORD_TOKEN=your_discord_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here

# Port for the web UI (default: 3000). On Replit this is set automatically.
PORT=3000

# Dashboard login — protect the web UI
DASHBOARD_USER=admin
DASHBOARD_PASS=your_strong_password_here

# ── Jira integration (optional) ──────────────────────────────────────────
# Required — without these the Jira button is hidden in the dashboard
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-atlassian-account@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=MCF

# Issue type to create (default: Task)
JIRA_ISSUE_TYPE=Task

# Custom field IDs — run "node get-jira-fields.js" to list all IDs
JIRA_FIELD_REPORT_TYPE=customfield_XXXXX
JIRA_FIELD_SENTIMENT=customfield_XXXXX
JIRA_FIELD_DISCORD_USERNAME=customfield_XXXXX
JIRA_FIELD_PLAYER_ID=customfield_XXXXX
JIRA_FIELD_SIMILAR_COUNT=customfield_XXXXX
JIRA_FIELD_DASHBOARD_LINK=customfield_XXXXX

# Public URL of this dashboard (filled into the Dashboard Link field in Jira)
DASHBOARD_URL=https://your-dashboard-url.com
